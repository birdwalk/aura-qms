# ============================================================
# AURA QMS — Microsoft Foundry Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ============================================================

# Azure AI Foundry Project Endpoint
# Found in: Azure AI Studio > Your Project > Overview > Project endpoint
VITE_AZURE_FOUNDRY_ENDPOINT=https://your-project.openai.azure.com/

# Azure AI Foundry API Key
# Found in: Azure AI Studio > Your Project > Keys and Endpoint
VITE_AZURE_API_KEY=your-api-key-here

# Orchestrator Agent ID (top-level agent that routes to sub-agents)
# Found in: Azure AI Studio > Agents > Your orchestrator agent > Agent ID
VITE_ORCHESTRATOR_AGENT_ID=asst_your-orchestrator-id

# Individual Agent IDs (created in Foundry Agent Service)
VITE_LEARNING_AGENT_ID=asst_your-learning-agent-id
VITE_DOCUMENT_AGENT_ID=asst_your-document-agent-id
VITE_AUDIT_AGENT_ID=asst_your-audit-agent-id
VITE_ASSESSMENT_AGENT_ID=asst_your-assessment-agent-id
VITE_TRAINING_AGENT_ID=asst_your-training-competency-agent-id
VITE_COMPLIANCE_AGENT_ID=asst_your-compliance-agent-id
VITE_INSIGHTS_AGENT_ID=asst_your-insights-agent-id

# Azure OpenAI Model Deployment Name
VITE_MODEL_DEPLOYMENT=gpt-4o

# Foundry IQ Knowledge Base ID
# Found in: Azure AI Studio > Knowledge bases > Your KB > ID
VITE_KNOWLEDGE_BASE_ID=your-knowledge-base-id

# API Version
VITE_AZURE_API_VERSION=2024-05-01-preview

# App Mode: "demo" uses hardcoded responses, "live" calls Foundry
# Set to "live" once your Foundry agents are deployed
VITE_APP_MODE=demo
